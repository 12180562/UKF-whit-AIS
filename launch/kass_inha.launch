<launch>
    <node pkg="kass_inha"  type="WP_pub.py"  name="WP_generator" respawn="true" />
    <!-- <node pkg="kass_inha"  type="static_obstacle_publish.py"  name="STOB" respawn="true" /> -->
    <node pkg="kass_inha"  type="KRISO.py"  name="KRISO" respawn="true" output="screen" />
    <node pkg="kass_inha"  type="PKNU.py" name="PKNU" respawn="true" /> 
    <node pkg="kass_inha"  type="ship_predict.py" name="ship_predict" respawn="true" /> 

    <!-- Comment out the unused vessel nodes -->
    <!-- Define the vessels' initial condition at the `/params/main_parameter.yaml` -->
    <node pkg="kass_inha"  type="vessel_node1.py"  name="ship1_Node"  respawn="true" output="screen"/>
    <node pkg="kass_inha"  type="vessel_node2.py"  name="ship2_Node"  respawn="true" output="screen"/>
    <node pkg="kass_inha"  type="vessel_node3.py"  name="ship3_Node"  respawn="true" />
    <!-- <node pkg="kass_inha"  type="vessel_node4.py"  name="ship4_Node"  respawn="true" /> 
    <node pkg="kass_inha"  type="vessel_node5.py"  name="ship5_Node"  respawn="true" /> -->

    <node pkg="kass_inha"  type="data_integration.py"  name="data_integration"  respawn="true"  output="screen"/>

    <!-- <node pkg="kass_inha"  type="data_visualizer.py" name="data_visualizer" respawn="true" output="screen"/> 
    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find kass_inha)/Disp/data_vis_inha.rviz"/> -->

	<rosparam command="load" file="$(find kass_inha)/params/main_parameter.yaml" />
    <rosparam command="load" file="$(find kass_inha)/params/KASS_Coefficient.yaml"/>     
    <rosparam command="load" file="$(find kass_inha)/params/park_parameter.yaml"/>
</launch>